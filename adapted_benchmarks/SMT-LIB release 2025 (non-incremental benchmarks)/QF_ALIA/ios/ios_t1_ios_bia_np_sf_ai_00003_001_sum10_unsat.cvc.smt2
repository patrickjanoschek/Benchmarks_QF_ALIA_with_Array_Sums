(assert (= a_12 (store a e_4 e_11)))
(assert (= a_14 (store a_12 e_0 e_13)))
(assert (= a_17 (store a_14 e_15 e_16)))
(assert (= a_3 (store a e_0 e_2)))
(assert (= a_6 (store a_3 e_4 e_5)))
(assert (= a_9 (store a_6 e_7 e_8)))
(assert (= e_0 (+ i 1)))
(assert (= e_1 (select a i)))
(assert (= e_10 (select a e_7)))
(assert (= e_11 (- e_10 1)))
(assert (= e_13 (- e_10 2)))
(assert (= e_15 (+ i 0)))
(assert (= e_16 (- e_10 3)))
